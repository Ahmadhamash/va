# ─── Database ────────────────────────────────────────────────────────────────
# Under docker-compose the host is overridden to "db" automatically.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_assistant_db
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=ai_assistant_db

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Fallback key. The admin can override it at runtime from the dashboard
# (stored in the DB) without a redeploy.
OPENAI_API_KEY=sk-replace-me

# ─── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── AWS S3 (For Backups or File Storage) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ─── Redis / task queue ──────────────────────────────────────────────────────
# Overridden to redis://redis:6379/0 automatically under docker-compose.
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ─── Auth ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-string-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ─── Files ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=25

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000"]
WEB_CONCURRENCY=4

# ─── Production Server ───────────────────────────────────────────────────────
DOMAIN=example.com
ACME_EMAIL=admin@example.com

# ─── Frontend (build arg) ────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
