# ─── Production env — copy to .env on the server and fill in ─────────────────

# Public domain (DNS A record must point at this server) and ACME email
DOMAIN=assistant.example.com
ACME_EMAIL=you@example.com

# Database (use strong values)
POSTGRES_USER=ai_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=ai_assistant_db
DATABASE_URL=postgresql+asyncpg://ai_user:CHANGE_ME_strong_db_password@db:5432/ai_assistant_db

# Redis
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# OpenAI fallback key (admin can override at runtime in the dashboard)
OPENAI_API_KEY=sk-replace-me

# Sentry
SENTRY_DSN=

# AWS S3 (For Backups or File Storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# Auth — generate: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Files
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=25

# App
APP_ENV=production
WEB_CONCURRENCY=4
CORS_ORIGINS=["https://assistant.example.com"]
NEXT_PUBLIC_API_URL=/api

# Chatwoot AI Bridge
CHATWOOT_BASE_URL=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_API_ACCESS_TOKEN=
CHATWOOT_BOT_AGENT_ID=
CHATWOOT_WEBHOOK_SECRET=
CHATWOOT_USER_ID=
AI_AUTO_REPLY_ENABLED=true
AI_HUMAN_HANDOFF_LABEL=human_handoff
