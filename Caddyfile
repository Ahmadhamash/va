{
    email {$ACME_EMAIL}
}

{$DOMAIN} {
    encode zstd gzip

    # Chatwoot webhook bridge → backend
    @chatwootWebhook path /webhooks/chatwoot
    handle @chatwootWebhook {
        reverse_proxy backend:8000
    }

    # Preview route for the new WhatsApp AI SaaS app
    @whatsappSaas path /wa-saas /wa-saas/*
    handle @whatsappSaas {
        reverse_proxy whatsapp-agent-saas:3000
    }

    # All API requests → backend
    @api path /api/*
    handle @api {
        reverse_proxy backend:8000
    }

    # Everything else → the React SPA (nginx)
    handle {
        reverse_proxy frontend:3000
    }
}

chat.masarjo.com {
    encode zstd gzip

    reverse_proxy chatwoot-rails:3000
}
