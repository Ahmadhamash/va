{$DOMAIN} {
    encode zstd gzip

    # All API requests → backend
    @api path /api/*
    handle @api {
        reverse_proxy backend:8000
    }

    # Everything else → the React SPA (nginx)
    handle {
        reverse_proxy frontend:3000
    }
}

chat.masarjo.com {
    encode zstd gzip

    reverse_proxy chatwoot-rails:3000
}
