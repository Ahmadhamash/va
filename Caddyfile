{
    auto_https off
}

:80 {
    encode zstd gzip

    @api {
        path /auth* /items* /chat* /admin* /style* /channels* /webhooks* /widget* /uploads* /health /docs /redoc /openapi.json
        not header Accept *text/html*
    }
    handle @api {
        reverse_proxy backend:8000
    }

    handle {
        reverse_proxy frontend:3000
    }
}
