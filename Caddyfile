{
    email {$ACME_EMAIL}
}

{$DOMAIN} {
    encode zstd gzip

    # Chatwoot webhook bridge -> backend
    @chatwootWebhook path /webhooks/chatwoot
    handle @chatwootWebhook {
        reverse_proxy backend:8000
    }

    # Legacy preview route now redirects to the main app
    @whatsappSaasLegacy path /wa-saas /wa-saas/*
    handle @whatsappSaasLegacy {
        redir * / 308
    }

    # API routes owned by the new Masar multi-channel SaaS app
    @masarSaasApi path /api/agent/* /api/channels/* /api/conversations* /api/knowledge* /api/onboarding/* /api/products* /api/whatsapp/*
    handle @masarSaasApi {
        reverse_proxy whatsapp-agent-saas:3000
    }

    # All remaining API requests -> existing backend
    @api path /api/*
    handle @api {
        reverse_proxy backend:8000
    }

    # Everything else -> the new Masar multi-channel SaaS app
    handle {
        reverse_proxy whatsapp-agent-saas:3000
    }
}

chat.masarjo.com {
    encode zstd gzip

    reverse_proxy chatwoot-rails:3000
}
